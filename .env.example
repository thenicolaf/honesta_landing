# Instagram DM link — used as the main CTA across the landing page
NEXT_PUBLIC_INSTAGRAM_DM_URL="https://ig.me/m/honesta_brand"
NEXT_PUBLIC_INSTAGRAM_BRAND_URL="https://www.instagram.com/honesta_brand"
NEXT_PUBLIC_INSTAGRAM_BRAND="honesta_brand"
NEXT_PUBLIC_EMAIL="honest@honesta.brand"

PUBLIC_BASE_URL="http://localhost:3000"
# N-Genius payment gateway (https://docs.ngenius-payments.com)
# Use sandbox URLs for testing, swap for production when ready
NGENIUS_API_URL="https://api-gateway.sandbox.ngenius-payments.com"
NGENIUS_API_KEY="your-service-account-api-key"
NGENIUS_OUTLET_REF="your-outlet-uuid"
# Optional: for webhook signature verification
# Payment Status
# {PUBLIC_BASE_URL}/api/payment/webhook
# x-webhook-secret
NGENIUS_WEBHOOK_SECRET="your-webhook-secret-header-value"

# Google Maps (https://console.cloud.google.com) — enable Maps JavaScript API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"